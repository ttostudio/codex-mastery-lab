+          <button type="button" data-filter="launch" aria-pressed="false">Launch</button>
+          <button type="button" data-filter="workflow" aria-pressed="false">Workflow</button>
+          <button type="button" data-filter="insight" aria-pressed="false">Insight</button>
+        </div>
+
+        <div class="grid">
+          <article class="card" data-category="launch">
+            <span class="art launch" aria-hidden="true"></span>
+            <p class="label">Launch</p>
+            <h3>Release Room</h3>
+            <p>Turn feature launches into crisp stories with assets, metrics, and stakeholder notes.</p>
+          </article>
+          <article class="card" data-category="workflow">
+            <span class="art workflow" aria-hidden="true"></span>
+            <p class="label">Workflow</p>
+            <h3>Pipeline Canvas</h3>
+            <p>Map handoffs from idea to adoption without adding another status meeting.</p>
+          </article>
+          <article class="card" data-category="insight">
+            <span class="art insight" aria-hidden="true"></span>
+            <p class="label">Insight</p>
+            <h3>Signal Board</h3>
+            <p>Show traction, risk, and customer pull in a dashboard executives can scan.</p>
+          </article>
+          <article class="card" data-category="workflow">
+            <span class="art connect" aria-hidden="true"></span>
+            <p class="label">Workflow</p>
+            <h3>Integration Shelf</h3>
+            <p>Package connected apps, use cases, and setup paths in reusable cards.</p>
+          </article>
+          <article class="card" data-category="launch">
+            <span class="art kit" aria-hidden="true"></span>
+            <p class="label">Launch</p>
+            <h3>Brand Kit</h3>
+            <p>Keep screenshots, messaging, quotes, and proof ready for every go-to-market push.</p>
+          </article>
+          <article class="card" data-category="insight">
+            <span class="art proof" aria-hidden="true"></span>
+            <p class="label">Insight</p>
+            <h3>Proof Wall</h3>
+            <p>Collect testimonials and adoption wins sales and success teams can reuse.</p>
+          </article>
+        </div>
+      </section>
+
+      <section id="proof" class="proof" aria-label="Customer proof">
+        <p>"Vibe Gallery gave our launch assets a premium home. Product, sales, and leadership finally reference the same story."</p>
+        <div><strong>Mara Chen</strong><span>VP Product, Northstar Labs</span></div>
