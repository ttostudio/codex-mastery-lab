+}
+
+.card p:last-child {
+  margin-bottom: 0;
+  color: var(--muted);
+  line-height: 1.55;
+}
+
+.proof,
+.demo {
+  margin: 34px 0;
+  border-radius: 8px;
+  border: 1px solid var(--line);
+  background: #fff;
+}
+
+.proof {
+  padding: 26px;
+  display: grid;
+  grid-template-columns: 1fr auto;
+  gap: 24px;
+  align-items: center;
+}
+
+.proof p {
+  margin-bottom: 0;
+  font-size: 1.25rem;
+  line-height: 1.45;
+}
+
+.proof span {
+  display: block;
+  margin-top: 4px;
+  color: var(--muted);
+}
+
+.demo {
+  justify-content: space-between;
