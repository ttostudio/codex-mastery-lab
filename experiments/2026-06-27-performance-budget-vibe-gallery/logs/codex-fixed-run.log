+.proof { background: radial-gradient(circle at 24% 58%, var(--coral) 0 22px, transparent 23px), linear-gradient(#cfd8df 0 0) 58% 34% / 34% 12px no-repeat, linear-gradient(#9eabb8 0 0) 58% 56% / 26% 12px no-repeat, #eef3f6; }
