+:root {
+  color-scheme: light;
+  --bg: #f5f7f8;
+  --ink: #17202a;
+  --muted: #5d6874;
+  --panel: #fff;
+  --line: #d9e0e7;
+  --teal: #0f766e;
+  --navy: #213b5a;
+  --coral: #d85f45;
+  --gold: #c8922e;
+}
+
+* { box-sizing: border-box; }
+
+html { scroll-behavior: smooth; }
+
+body {
+  margin: 0;
+  color: var(--ink);
+  background: linear-gradient(140deg, #eef8f5 0 34%, var(--bg) 34% 100%);
+  font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
+}
+
+a { color: inherit; text-decoration: none; }
+
+.topbar,
